datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

/// The underlying table does not contain a valid unique identifier and can therefore currently not be handled by Prisma Client.
model android_metadata {
  locale String?

  @@ignore
}

model app_preferences {
  key        String @id
  value      String
  updated_at String
}

model capabilities {
  id                 String               @id
  name               String               @unique(map: "index_capabilities_name")
  model_capabilities model_capabilities[]
}

model model_capabilities {
  model_id      Int
  capability_id String
  source        String?
  capabilities  capabilities @relation(fields: [capability_id], references: [id], onDelete: Cascade)
  models        models       @relation(fields: [model_id], references: [id], onDelete: Cascade)

  @@id([model_id, capability_id])
  @@index([capability_id], map: "index_model_capabilities_capability_id")
}

model models {
  id                 Int                  @id @default(autoincrement())
  provider_id        String
  external_id        String
  model_name         String
  model_capabilities model_capabilities[]
  providers          providers            @relation(fields: [provider_id], references: [id], onDelete: Cascade)

  @@unique([provider_id, external_id], map: "index_models_provider_id_external_id")
  @@index([model_name], map: "index_models_model_name")
  @@index([provider_id, model_name], map: "index_models_provider_id_model_name")
  @@index([external_id], map: "index_models_external_id")
  @@index([provider_id], map: "index_models_provider_id")
}

model providers {
  id             String   @id
  name           String
  last_synced_at Int
  api_token      String?
  models         models[]
}

model room_master_table {
  id            Int     @id @default(autoincrement())
  identity_hash String?
}

model transcriptions {
  id                   Int     @id @default(autoincrement())
  original_text        String
  processed_text       String?
  audio_file_path      String?
  stt_model            String?
  llm_model            String?
  created_at           String
  post_processing_type String?
  status               String
  error_message        String?
  seen                 Int     @default(0)
  retry_count          Int     @default(0)
  summary              String?
}

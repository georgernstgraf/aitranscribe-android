datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

/// The underlying table does not contain a valid unique identifier and can therefore currently not be handled by Prisma Client.
model android_metadata {
  locale String?

  @@ignore
}

model models {
  id           String
  provider_id  String
  model_name   String
  capabilities String?
  providers    providers @relation(fields: [provider_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([id, provider_id])
  @@index([provider_id], map: "index_models_provider_id")
}

model providers {
  id             String   @id
  display_name   String
  last_synced_at Int
  models         models[]
}

model room_master_table {
  id            Int     @id @default(autoincrement())
  identity_hash String?
}

model transcriptions {
  id                   Int     @id @default(autoincrement())
  original_text        String
  processed_text       String?
  audio_file_path      String?
  created_at           String
  post_processing_type String?
  status               String
  error_message        String?
  played_count         Int
  retry_count          Int
  summary              String?
  stt_model            String?
  llm_model            String?
}

SELECT
    *
FROM
    capabilities
WHERE
    id LIKE '%audio%'
    OR name LIKE '%audio%';

SELECT DISTINCT
    m.*
FROM
    models AS m
    JOIN model_capabilities AS mc ON m.id = mc.model_id
    JOIN capabilities AS c ON mc.capability_id = c.id
WHERE
    c.id LIKE '%audio%'
    OR c.name LIKE '%audio%';

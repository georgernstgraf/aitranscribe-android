datasource db {
    provider = "sqlite"
    url      = env("DATABASE_URL")
}

/// The underlying table does not contain a valid unique identifier and can therefore currently not be handled by Prisma Client.
model android_metadata {
    locale String?

    @@ignore
}

model provider {
    id             String           @id
    name           String           @unique
    last_synced_at Int
    models         provider_model[]
    api_token      String?
}

model provider_model {
    id                Int                @id @default(autoincrement())
    providerId        String
    externalId        String
    name              String
    provider          provider           @relation(fields: [providerId], references: [id], onDelete: Cascade)
    modelCapabilities model_capability[]

    @@unique([providerId, externalId])
    @@index([providerId])
    @@index([name])
}

model capability {
    id                String             @id
    name              String             @unique
    modelCapabilities model_capability[]
}

model model_capability {
    modelId          Int
    capabilityId    String
    source          String?
    capability      capability     @relation(fields: [capabilityId], references: [id], onDelete: Cascade)
    model           provider_model @relation(fields: [modelId], references: [id], onDelete: Cascade)

    @@id([modelId, capabilityId])
    @@index([capabilityId])
    @@index([modelId])
}

model room_master_table {
    id            Int     @id @default(autoincrement())
    identity_hash String?
}

model transcriptions {
    id              Int      @id @default(autoincrement())
    audio_file_path String?
    original_text   String
    processed_text  String?
    summary         String?
    created_at      DateTime @default(now())
    status          String /// ENUM-like status, stored as TEXT
    error_message   String?
    seen            Boolean  @default(false)

    @@index([created_at])
    @@index([status])
}

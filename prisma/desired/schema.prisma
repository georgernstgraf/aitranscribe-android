datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

/// The underlying table does not contain a valid unique identifier and can therefore currently not be handled by Prisma Client.
model android_metadata {
  locale String?

  @@ignore
}

model app_preferences {
  key        String @id
  value      String
  updated_at String
}

model languages {
  id             String           @id
  name           String
  native_name    String?
  is_active      Int              @default(1)
  transcriptions transcriptions[]
}

model models {
  id          Int      @id @default(autoincrement())
  provider_id String
  external_id String
  model_name  String
  providers   providers @relation(fields: [provider_id], references: [id], onDelete: Cascade)

  @@unique([provider_id, external_id], map: "index_models_provider_id_external_id")
  @@index([model_name], map: "index_models_model_name")
  @@index([provider_id, model_name], map: "index_models_provider_id_model_name")
  @@index([external_id], map: "index_models_external_id")
  @@index([provider_id], map: "index_models_provider_id")
}

model providers {
  id             String   @id
  name           String
  last_synced_at Int
  api_token      String?
  models         models[]
}

model room_master_table {
  id            Int     @id @default(autoincrement())
  identity_hash String?
}

model transcriptions {
  id              Int        @id @default(autoincrement())
  stt_text        String?
  cleaned_text    String?
  audio_file_path String?
  created_at      String
  error_message   String?
  seen            Int        @default(0)
  summary         String?
  languagesId     String?
  languages       languages? @relation(fields: [languagesId], references: [id])

  @@index([languagesId], map: "index_transcriptions_languagesId")
}
